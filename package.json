{
  "name": "mdreview",
  "version": "0.3.10",
  "description": "An app for design review of software projects",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@mdreview/chrome-ext",
    "build": "turbo run build",
    "build:ext": "turbo run build --filter=@mdreview/chrome-ext",
    "dev:electron": "turbo run dev --filter=@mdreview/electron",
    "build:electron": "turbo run build --filter=@mdreview/electron",
    "export:docx": "tsx scripts/export-docx-mermaid-cli.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest --run",
    "test:e2e": "playwright test",
    "lint": "eslint packages --ext ts,tsx",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "clean": "rm -rf packages/*/dist packages/*/out .turbo node_modules/.vite",
    "check": "bun run lint && bun run test:ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdreview/core": "workspace:*",
    "@jamesainslie/docx": "^9.5.1-svg.1",
    "dompurify": "^3.0.6",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/chrome": "^0.0.254",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^27.0.0",
    "@types/markdown-it": "^13.0.9",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.7",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.1",
    "panzoom": "^9.4.3",
    "playwright": "^1.48.0",
    "prettier": "^3.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^7.2.6",
    "turbo": "^2.5.0",
    "vitest": "^4.0.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaklabco/mdreview.git"
  },
  "keywords": [
    "markdown",
    "viewer",
    "chrome-extension",
    "mermaid",
    "syntax-highlighting",
    "themes"
  ],
  "author": "James Ainslie",
  "license": "MIT",
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
