{
  "name": "@mdreview/core",
  "version": "0.1.0",
  "description": "Core rendering engine for mdreview",
  "type": "module",
  "files": [
    "dist",
    "styles"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./sw": {
      "types": "./dist/sw.d.ts",
      "import": "./dist/sw.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./utils/debug-logger": {
      "types": "./dist/utils/debug-logger.d.ts",
      "import": "./dist/utils/debug-logger.js"
    },
    "./styles/content.css": "./styles/content.css"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:ci": "vitest --run",
    "prepublishOnly": "bun run build && bun run test:ci"
  },
  "dependencies": {
    "@jamesainslie/docx": "^9.5.1-svg.1",
    "dompurify": "^3.0.6",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.12.1",
    "panzoom": "^9.4.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^13.0.9",
    "jszip": "^3.10.1",
    "tsup": "^8"
  },
  "author": "James Ainslie",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
